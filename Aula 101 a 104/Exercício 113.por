programa {
  funcao inicio() {
    inteiro numero [5]


    escreva("Digite um número: ")
    leia(numero[0])

    escreva("Digite doi número: ")
    leia(numero[1])

    escreva("Digite três número: ")
    leia(numero[2])

    
    numero[3] = 2
    numero[4] = 4

    escreva(numero[0], "\n")
    escreva(numero[1], "\n")
    escreva(numero[2], "\n")
    escreva(numero[3], "\n")
    escreva(numero[4])
   
   

  }
}

programa {
  funcao inicio() {
    inteiro numero[4] = {10, 3, 40, 30}

    inteiro soma = numero[0] + numero[1] + numero[2] + numero[3]
    inteiro multiplicacao = numero[1] * numero[2]
    inteiro subtracao = numero[2] - numero[0]

    escreva("Soma dos números é: ", soma, "\n")
    escreva("Soma da multiplicação é: ", multiplicacao, "\n") 
    escreva("Soma da subtração é: ", subtracao)
  }
}
  
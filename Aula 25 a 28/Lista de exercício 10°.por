programa {
  funcao inicio() {
    real mamao, acucar

    escreva("Valor do mamão R$: ")
    leia(mamao)

    escreva("Valor do açucar R$: ")
    leia(acucar)

    mamao = (mamao /5)
    acucar = (acucar /5)

    escreva("A prestação do mamão é R$: ", mamao, "\n")
    escreva("A prestação do açucar é R$: ", acucar)
   

  

  }

}

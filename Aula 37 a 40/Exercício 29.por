programa {
  funcao inicio() {
    inteiro dataDeNasciemento, anoAtual = 2026, idade 

    escreva("Digite sua data de nascimento: ")
    leia(dataDeNasciemento)

    idade = ( anoAtual - dataDeNasciemento)

    se( idade >= 18) {

      escreva("Permitido votar")

    } senao 
     escreva("Não é permitido votar")


  }
}

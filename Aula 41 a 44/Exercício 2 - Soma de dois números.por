programa {
  funcao inicio() {
    real a, b, soma

    escreva("Digite A: ")
    leia(a)

    escreva("Digite B: ")
    leia(b)

    soma = a + b

    escreva("Soma = ", soma)

    // A variavel "inteiro" está errada a correta é "real"
    // A conta está errada inves de somar colocou sinal de multiplicar "*"
  }
}

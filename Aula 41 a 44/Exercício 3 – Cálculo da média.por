programa
{
    funcao inicio()
    {
        real n1, n2, media
        escreva("Digite número n1: ")
        leia(n1)

        escreva("Digite número n2: ")
        leia(n2)

        media = (n1 + n2) / 2

        escreva("Média: ", media)

        // O erro é a falta do escreva antes do "leia"
        // é tinha erro da divisão 
    }
}
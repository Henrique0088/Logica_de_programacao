programa
{
    funcao inicio()
    {
       real largura, altura
        real area

        escreva("Digite a lagura: ")
        leia(largura)

        escreva("Digite a altura: ")
        leia(altura)

        area = largura * altura

        escreva("Área: ", area)

        // O erro é  a falta do escreva antes do leia
        // A variavel está errada as 2 são real
    }
}
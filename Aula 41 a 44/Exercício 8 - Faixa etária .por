programa
{
    funcao inicio()
    {
        inteiro idade

        escreva("Digite sua idade: ")
        leia(idade)

        se (idade >= 12 ou idade >= 17)
        {
            escreva("Adolescente")
        }
        senao 
        {
            escreva("Não é adolescente")
        }


        //O erro é a falta do escreva antes do leia
        // o sinal de maior estava do lado errado
    }
}
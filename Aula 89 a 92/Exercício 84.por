programa {
  funcao verificarNumeros() {
    escreva("Digite um número", "\n")
  }
  funcao inicio (){
   verificarNumeros()
 
     inteiro numero  

     faca{
      
     escreva("Numero digite um numero: ", numero)
     leia(numero)

      se(numero < 0){
        escreva("negativo", "\n")
      }senao{
        escreva("positivo", "\n")
      }
     }enquanto(numero != 0)
  }
}

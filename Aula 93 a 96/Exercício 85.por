programa {
  funcao areaRentaulo(real base, real altura) {
    real

    area = base * altura

    escreva("Área do retângulo: ", area, " cm2")
  }

   funcao inicio (){
    real base, altura

    escreva("Informe a base do rentâgulo em cm: ")
    leia(base)

    escreva("Informe a altura do rentângulo em cm: ")
    leia(altura)

    areaRentaulo(base, altura)
   }
   
}
